<!-- vim_templates.xml - Basic Vim editing for coding. Keep minimal to avoid long system prompts. -->

<!-- Read file (use :%print # for line numbers - avoids off-by-one) -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:%print #
]]></commands>
</tool_call>

<!-- Insert after line number: :N then o (below) or O (above) -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:5
o
  // new code
  // new code 2
\x1b
]]></commands>
</tool_call>

<!-- Insert after line or pattern -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:/^export function/
o
  // new code
  // new code 2
\x1b
]]></commands>
</tool_call>

<!-- Replace line: use :Nd (delete) then o (insert). Do NOT use substitute. -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:5
dd
o
  const x = 1;
\x1b
:%print #
]]></commands>
</tool_call>

<!-- Delete line(s) by number: :Nd (single) or :N,Md (range). Delete bottom-to-top for non-contiguous -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:5d
:%print #        
]]></commands>
</tool_call>

<!-- Delete range :5,10d (lines 5–10 inclusive). Non-contiguous: delete higher line numbers first -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:5,10d
:%print #
]]></commands>
</tool_call>

<!-- Delete lines matching pattern -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/index.ts
:g/console\.log/d
]]></commands>
</tool_call>

<!-- Diff two files -->
<tool_call name="vim">
  <commands><![CDATA[
:diff src/old.ts src/new.ts
]]></commands>
</tool_call>

<!-- Create new file -->
<tool_call name="vim">
  <commands><![CDATA[
:e src/Component.tsx
i
export const Component = () => <div>Hello</div>;
\x1b
:w
]]></commands>
</tool_call>
