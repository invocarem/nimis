<!-- vim_templates.xml -->
<!-- Essential Vim editing patterns. See NIMIS_INTRODUCTION for more examples. -->

<!-- Read file content -->
<tool_call name="vim">
  <file_path>src/index.ts</file_path>
  <commands><![CDATA[
:e src/index.ts
:%print
]]></commands>
</tool_call>

<!-- Insert at end of file -->
<tool_call name="vim">
  <file_path>src/index.ts</file_path>
  <commands><![CDATA[
:e src/index.ts
G
o
export const VERSION = '1.0.0';
\x1b
:w
]]></commands>
</tool_call>

<!-- Global substitution -->
<tool_call name="vim">
  <file_path>src/index.ts</file_path>
  <commands><![CDATA[
:e src/index.ts
:%s/var/const/g
:w
:%print
]]></commands>
</tool_call>

<!-- Delete lines matching pattern -->
<tool_call name="vim">
  <file_path>src/index.ts</file_path>
  <commands><![CDATA[
:e src/index.ts
:g/console\.log/d
:w
]]></commands>
</tool_call>

<!-- Create new file -->
<tool_call name="vim">
  <file_path>src/components/Button.tsx</file_path>
  <commands><![CDATA[
i
import React from 'react';

export const Button: React.FC = () => <button>Click</button>;

\x1b
:w
]]></commands>
</tool_call>
